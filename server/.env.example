# Server Configuration
SERVER_ADDR=0.0.0.0:8080

# Database Configuration
DATABASE_URL=postgres://user:password@localhost:5432/to_do_list

# Database Connection Pool
DB_POOL_MAX_SIZE=10

# Environment
ENVIRONMENT=development

# Logging
LOG_LEVEL=info

# Google OAuth 2.0 Configuration
# Register your application at https://console.cloud.google.com/apis/credentials
# and set the authorized redirect URI to match your server
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/auth/callback
